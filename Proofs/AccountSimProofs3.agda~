                           -> (par ⊢ getS l ctx ~[ i ]~> getS' ctx
                              × continuing ctx ≡ true
                              × checkTokenIn (l .fst) ctx ≡ true
                              × checkTokenOut (l .fst) ctx ≡ true)
                              

